# Virtual environments
venv/
app/.buildvenv/
windows-msi/.buildvenv/

# Build output (regenerated by the build scripts / CI)
app/build/
app/dist/
app/*.spec
app/markdownify.iconset/
app/markdownify.icns
app/icon_master.png

# Large ML models — CI downloads these fresh via fetch_models.py (~1.2 GB)
app/assets/docling_models/

# Installers (large; produced by builds / CI artifacts)
macos-pkg/*.pkg
macos-pkg/stage/
windows-msi/*.msi

# Code-signing PRIVATE key material — must NEVER be committed.
windows-msi/signing/
# ...but the PUBLIC cert (for Intune) is safe to commit (exception below).
windows-msi/*.cer
!windows-msi/1FD-CodeSigning-Public.cer

# Python cruft
**/__pycache__/
*.pyc

# macOS cruft
.DS_Store
**/.DS_Store
